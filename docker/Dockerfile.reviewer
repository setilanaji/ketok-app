FROM node:22-alpine
RUN npm install -g opencode-ai

WORKDIR /reviewer

# Bake in default rules and skills
COPY .opencode/ /defaults/.opencode/

# Mount point — consumers can bind-mount their own .opencode/ here to override defaults
VOLUME ["/reviewer/.opencode"]

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
